# ── Resend (waitlist email collection) ──────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Create a free account → Resend dashboard → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Audience ID where waitlist signups are stored.
# Resend dashboard → Audiences → Create Audience → copy the ID (looks like a UUID)
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Google sign-in logging (app/api/auth/log) ────────────────────────────────
# The Friday desktop app POSTs the Google id_token here after sign-in; this route
# verifies it and records the user in D1. This must be the SAME OAuth client id the
# desktop app uses (MAIN_VITE_GOOGLE_OAUTH_CLIENT_ID) — it's checked as the token's
# `aud`, so a mismatch rejects every login. Not a secret (it's a desktop client id),
# but set it as a Cloudflare var for prod: `wrangler secret put GOOGLE_OAUTH_CLIENT_ID`.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
